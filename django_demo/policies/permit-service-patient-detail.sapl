policy "permit-service-patient-detail"
permit
  action == "service:getPatientDetail";
  resource.type == "patientDetail";
obligation
  {
    "type": "filterJsonContent",
    "actions": [
      {
        "type": "blacken",
        "path": "$.ssn",
        "replacement": "*",
        "discloseRight": 4
      }
    ]
  }
